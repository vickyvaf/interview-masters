---
const faqs = [
  {
    question: "Bagaimana simulasi wawancara kerja AI ini bekerja?",
    answer:
      "AI kami akan mengajukan pertanyaan satu per satu secara interaktif berdasarkan posisi pekerjaan yang Anda pilih serta deskripsi pekerjaan yang diunggah. Anda cukup menjawab secara lisan menggunakan mikrofon, dan mesin transkripsi kami akan mencatat tanggapan Anda secara real-time untuk dianalisis oleh AI evaluator.",
  },
  {
    question:
      "Apakah saya langsung mendapatkan umpan balik setelah latihan selesai?",
    answer:
      "Ya! Segera setelah simulasi selesai, Anda akan disuguhkan dasbor analisis terperinci. Feedback kami mencakup penilaian struktur kalimat (menggunakan metode STAR: Situation, Task, Action, Result), tingkat relevansi, kepadatan penjelasan, pendeteksi rambling (bicara berputar-putar), serta rekomendasi revisi jawaban ('What you could have said').",
  },
  {
    question: "Metode pembayaran apa saja yang didukung?",
    answer:
      "Kami menerima berbagai metode pembayaran lokal Indonesia yang aman, termasuk pembayaran instan menggunakan QRIS, Virtual Account (BCA, Mandiri, BRI, BNI, dll), e-wallet, dan kartu debit/kredit lokal.",
  },
  {
    question: "Apa perbedaan paket Pro bulanan dengan Starter Pass?",
    answer:
      "Paket Pro (Rp 29.000/bulan) memberikan akses latihan tanpa batas (unlimited) dan analitik lengkap setiap bulan. Sementara Starter Pass (Rp 9.000/paket) adalah paket sekali bayar tanpa langganan yang memberikan kuota 3x simulasi wawancara dengan masa aktif 1 bulan, dirancang bagi Anda yang ingin latihan cepat tanpa ikatan berlangganan.",
  },
  {
    question: "Apakah saya bisa membatalkan langganan Pro kapan saja?",
    answer:
      "Tentu saja. Anda bisa membatalkan langganan paket Pro Anda kapan saja langsung melalui menu Billing di dasbor akun Anda. Setelah dibatalkan, akses fitur Pro akan tetap aktif hingga periode langganan bulan berjalan berakhir.",
  },
];
---

<section id="faq" class="w-full py-20 bg-background border-t border-border/30">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Header -->
    <div
      class="text-center flex flex-col items-center gap-4 mb-16 faq-element opacity-0 translate-y-8 transition-all duration-700 ease-out transform"
    >
      <h2
        class="text-3xl md:text-4xl font-extrabold text-foreground tracking-tight leading-tight"
      >
        Pertanyaan yang Sering Diajukan (FAQ)
      </h2>
      <p class="text-sm md:text-base text-muted-foreground leading-relaxed">
        Masih punya pertanyaan? Temukan jawabannya di bawah ini mengenai cara
        kerja platform simulasi wawancara kami.
      </p>
    </div>

    <!-- Accordion Wrapper -->
    <div
      class="flex flex-col gap-4 faq-element opacity-0 translate-y-8 transition-all duration-700 ease-out transform delay-100"
    >
      {
        faqs.map((faq, index) => (
          <details class="group border border-border/50 bg-card rounded-2xl overflow-hidden [&_summary::-webkit-details-marker]:hidden transition-all duration-300 open:shadow-md open:shadow-primary/5">
            <summary class="flex justify-between items-center p-6 text-foreground font-semibold cursor-pointer list-none select-none hover:bg-secondary/40 transition-colors">
              <span class="text-sm md:text-base pr-4 leading-snug">
                {faq.question}
              </span>
              <span class="transition-transform duration-300 group-open:rotate-180 shrink-0 text-muted-foreground">
                <svg
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19 9l-7 7-7-7"
                  />
                </svg>
              </span>
            </summary>
            <div class="px-6 pb-6 pt-1 text-xs md:text-sm text-muted-foreground leading-relaxed border-t border-border/20">
              {faq.answer}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove("opacity-0", "translate-y-8");
          entry.target.classList.add("opacity-100", "translate-y-0");
          observer.unobserve(entry.target);
        }
      });
    },
    {
      threshold: 0.1,
    },
  );

  document.querySelectorAll(".faq-element").forEach((el) => {
    observer.observe(el);
  });
</script>
