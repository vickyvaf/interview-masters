---

<footer class="border-t border-border/40 w-full py-16 bg-background">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Top Grid -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8 pb-12">
      <!-- Column 1: Brand description -->
      <div class="col-span-2 flex flex-col gap-3">
        <span class="font-bold text-foreground text-lg tracking-tight"
          >Interview Masters</span
        >
        <p class="text-sm text-muted-foreground max-w-xs leading-relaxed">
          Master your interviews with realistic, repeatable mock practice and
          structured, actionable feedback.
        </p>
      </div>

      <!-- Column 2: Product -->
      <div class="flex flex-col gap-3">
        <span class="font-semibold text-foreground text-sm tracking-wide"
          >Product</span
        >
        <ul class="flex flex-col gap-2.5 text-sm">
          <li>
            <a href="#" class="hover:text-foreground transition-colors"
              >Features</a>
          </li>
          <li>
            <a href="#" class="hover:text-foreground transition-colors"
              >Pricing</a>
          </li>
          <li>
            <a href="#" class="hover:text-foreground transition-colors"
              >Integrations</a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Resources -->
      <div class="flex flex-col gap-3">
        <span class="font-semibold text-foreground text-sm tracking-wide"
          >Resources</span
        >
        <ul class="flex flex-col gap-2.5 text-sm">
          <li>
            <a href="#" class="hover:text-foreground transition-colors"
              >Interview Guide</a>
          </li>
          <li>
            <a href="#" class="hover:text-foreground transition-colors"
              >STAR Method</a>
          </li>
          <li>
            <a href="#" class="hover:text-foreground transition-colors"
              >Success Stories</a>
          </li>
          <li>
            <a href="#" class="hover:text-foreground transition-colors">FAQ</a>
          </li>
        </ul>
      </div>

      <!-- Column 4: Company -->
      <div class="flex flex-col gap-3">
        <span class="font-semibold text-foreground text-sm tracking-wide"
          >Company</span
        >
        <ul class="flex flex-col gap-2.5 text-sm">
          <li>
            <a href="#" class="hover:text-foreground transition-colors"
              >About Us</a>
          </li>
          <li>
            <a href="#" class="hover:text-foreground transition-colors"
              >Careers</a>
          </li>
          <li>
            <a href="#" class="hover:text-foreground transition-colors">Blog</a>
          </li>
          <li>
            <a href="#" class="hover:text-foreground transition-colors"
              >Contact</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div
      class="border-t border-border/20 pt-8 flex flex-col md:flex-row items-center justify-between text-xs text-muted-foreground gap-4"
    >
      <div>
        <span
          >&copy; {new Date().getFullYear()} Interview Masters. All rights reserved.</span
        >
      </div>
      <div class="flex items-center gap-6">
        <a href="#" class="hover:text-foreground transition-colors"
          >Privacy Policy</a
        >
        <a href="#" class="hover:text-foreground transition-colors"
          >Terms of Service</a
        >
        <a href="#" class="hover:text-foreground transition-colors"
          >Cookies Settings</a
        >
      </div>
    </div>
  </div>
</footer>
