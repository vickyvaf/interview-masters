---

<section id="features" class="w-full py-20 bg-background">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Top Row: Content & Video Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left side: Info -->
      <div class="learn-element opacity-0 translate-y-8 transition-all duration-700 ease-out transform flex flex-col gap-6 text-left">
        <h2 class="text-3xl md:text-4xl font-extrabold text-foreground tracking-tight leading-tight">
          Practice with Top-Tier Industry Experts
        </h2>
        <p class="text-sm md:text-base text-muted-foreground leading-relaxed max-w-xl">
          At Interview Masters, we pride ourselves on offering tracks designed and verified by leading experts actively conducting interviews at renowned companies such as Netflix, Spotify, Google, and Stripe. Our mock repository is continually refreshed to align with the most recent industry standards, guaranteeing that you are equipped with standard frameworks and winning techniques.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 mt-2 w-full">
          <a href="#" class="w-full sm:w-auto text-center px-5 py-3 sm:px-6 sm:py-3 text-xs sm:text-sm font-semibold rounded-xl bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
            Browse Our Tracks
          </a>
          <a href="#" class="w-full sm:w-auto text-center px-5 py-3 sm:px-6 sm:py-3 text-xs sm:text-sm font-semibold rounded-xl bg-secondary text-secondary-foreground border border-border/40 hover:bg-secondary/80 transition-colors">
            Explore Jobs
          </a>
        </div>
      </div>

      <!-- Right side: Video Player Mockup -->
      <div class="learn-element opacity-0 translate-y-8 transition-all duration-700 ease-out transform">
        <div class="relative rounded-3xl overflow-hidden border border-border/50 aspect-video w-full group cursor-pointer bg-card">
          <img src="/video-placeholder.png" alt="Video tutorial mockup" class="w-full h-full object-cover" />
          <div class="absolute inset-0 flex items-center justify-center bg-black/25 group-hover:bg-black/40 transition-colors">
            <div class="w-16 h-16 rounded-full bg-primary text-primary-foreground flex items-center justify-center transform group-hover:scale-110 transition-transform">
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 translate-x-0.5">
                <polygon points="5 3 19 12 5 21 5 3" />
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', 'translate-y-8');
        entry.target.classList.add('opacity-100', 'translate-y-0');
        observer.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.1
  });

  document.querySelectorAll('.learn-element').forEach((el) => {
    observer.observe(el);
  });
</script>
