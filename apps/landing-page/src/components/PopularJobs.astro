---
const jobs = [
  {
    title: "Software Engineer",
    description: "Prepare for coding rounds, system design, and algorithmic problem-solving at top-tier tech companies.",
    emoji: "👩‍💻"
  },
  {
    title: "Product Manager",
    description: "Master product strategy, metric execution, system design, and behavioral frameworks.",
    emoji: "👩‍💼"
  },
  {
    title: "Data Science & AI",
    description: "Practice machine learning design, probability, statistical models, and SQL challenges.",
    emoji: "👩‍🔬"
  },
  {
    title: "Consulting & Finance",
    description: "Ace case studies, financial evaluation frameworks, models, and market sizing estimations.",
    emoji: "👨‍💼"
  },
  {
    title: "Product Designer",
    description: "Perfect your portfolio presentations, interactive design critique, and whiteboard execution challenges.",
    emoji: "👩‍🎨"
  },
  {
    title: "Operations & Management",
    description: "Align logistic planning, operational cases, supply chain systems, and team management cases.",
    emoji: "👷‍♂️"
  }
];
---

<section class="w-full pt-32 pb-20 bg-background">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Header -->
    <div class="flex items-end justify-between mb-10">
      <div class="flex flex-col gap-2">
        <h2 class="text-3xl font-extrabold text-foreground tracking-tight">Popular Curated Job Tracks</h2>
        <p class="text-sm text-muted-foreground">Follow a clear mock-practice track and master the tools needed to land top roles.</p>
      </div>
      <a href="#" class="text-sm font-semibold text-foreground/80 hover:text-foreground hover:underline flex items-center gap-1 transition-colors">
        View more
      </a>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {jobs.map((job) => (
        <div class="job-card relative group flex flex-col md:flex-row gap-6 p-6 rounded-3xl bg-card border border-border/40 hover:border-border/80 opacity-0 translate-y-8 transition-all duration-700 ease-out transform">
          <!-- Icon Graphic Area -->
          <div class="flex-shrink-0 w-20 h-20 rounded-2xl flex items-center justify-center bg-muted/20 border border-border/30 text-3xl select-none">
            {job.emoji}
          </div>

          <!-- Content Area -->
          <div class="flex-1 flex flex-col justify-between">
            <div>
              <a href="#" class="inline-flex items-center gap-1 text-lg font-bold text-foreground hover:text-primary transition-colors group">
                {job.title}
              </a>
              <p class="text-sm text-muted-foreground mt-2 leading-relaxed">{job.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', 'translate-y-8');
        entry.target.classList.add('opacity-100', 'translate-y-0');
        observer.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.1
  });

  document.querySelectorAll('.job-card').forEach((card) => {
    observer.observe(card);
  });
</script>
