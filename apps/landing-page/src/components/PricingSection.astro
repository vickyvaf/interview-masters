            >
          </div>
          <p class="text-xs text-muted-foreground">
            Persiapan intensif waktu singkat
          </p>
        </div>

        <div class="flex items-baseline gap-1.5 flex-nowrap whitespace-nowrap">
          <span class="text-3xl font-extrabold text-foreground tracking-tight"
