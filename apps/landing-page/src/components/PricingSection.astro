---
const dashboardUrl = import.meta.env.PUBLIC_DASHBOARD_URL || 'http://localhost:5173';
---

<section id="pricing" data-dashboard-url={dashboardUrl} class="w-full py-20 bg-background border-t border-border/30">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Header -->
    <div
      class="text-center flex flex-col items-center gap-4 mb-16 pricing-element opacity-0 translate-y-8 transition-all duration-700 ease-out transform"
    >
      <h2
        class="text-3xl md:text-4xl font-extrabold text-foreground tracking-tight leading-tight"
      >
        Pilihan Paket & Layanan
      </h2>
      <p
        class="text-sm md:text-base text-muted-foreground leading-relaxed max-w-xl"
      >
        Pilih paket yang paling sesuai untuk meningkatkan kesiapan dan
        kepercayaan diri Anda menghadapi wawancara kerja.
      </p>
    </div>

    <!-- Grid -->
    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch pricing-element opacity-0 translate-y-8 transition-all duration-700 ease-out transform delay-100"
    >
      <!-- Free Plan -->
      <div
        class="rounded-3xl border border-border/50 bg-card p-8 flex flex-col gap-6 h-full transition-all duration-300 hover:shadow-lg hover:shadow-primary/5"
      >
        <div class="flex flex-col gap-1">
          <h3 class="text-xl font-bold text-foreground">Free</h3>
          <p class="text-xs text-muted-foreground">Untuk perkenalan awal</p>
        </div>

        <div class="flex items-baseline gap-1.5 flex-nowrap whitespace-nowrap">
          <span class="text-3xl font-extrabold text-foreground tracking-tight"
            >Rp 0</span
          >
          <span class="text-sm text-muted-foreground">/ bulan</span>
        </div>

        <hr class="border-border/40" />

        <ul class="flex flex-col gap-3 flex-grow text-sm">
          <li class="flex items-start gap-3 text-foreground">
            <svg
              class="w-5 h-5 text-emerald-500 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Umpan balik dasar (basic feedback)</span>
          </li>
        </ul>

        <a
          href={`${dashboardUrl}/register`}
          class="w-full text-center py-3 text-sm font-semibold rounded-xl border border-border hover:bg-secondary text-foreground transition-all"
        >
          Mulai Gratis
        </a>
      </div>

      <!-- Pro Plan -->
      <div
        class="rounded-3xl border-2 border-primary bg-card p-8 flex flex-col gap-6 h-full relative transition-all duration-300 hover:shadow-lg hover:shadow-primary/5"
      >
        <div
          class="absolute -top-3.5 right-6 px-3 py-1 bg-primary text-primary-foreground text-xs font-bold rounded-full flex items-center gap-1"
        >
          <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24">
            <path
              d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"
            ></path>
          </svg>
          Populer
        </div>

        <div class="flex flex-col gap-1">
          <h3 class="text-xl font-bold text-foreground">Pro</h3>
          <p class="text-xs text-muted-foreground">Untuk pencari kerja aktif</p>
        </div>

        <div class="flex items-baseline gap-1.5 flex-nowrap whitespace-nowrap">
          <span class="text-3xl font-extrabold text-foreground tracking-tight"
            >Rp 99.000</span
          >
          <span class="text-sm text-muted-foreground">/ bulan</span>
        </div>

        <hr class="border-border/40" />

        <ul class="flex flex-col gap-3 flex-grow text-sm">
          <li class="flex items-start gap-3 text-foreground">
            <svg
              class="w-5 h-5 text-emerald-500 shrink-0 mt-0.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Sesi latihan tanpa batas (unlimited)</span>
          </li>
          <li class="flex items-start gap-3 text-foreground">
            <svg
              class="w-5 h-5 text-emerald-500 shrink-0 mt-0.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Umpan balik AI tingkat lanjut</span>
          </li>
          <li class="flex items-start gap-3 text-foreground">
            <svg
              class="w-5 h-5 text-emerald-500 shrink-0 mt-0.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Analitik progres latihan</span>
          </li>
          <li class="flex items-start gap-3 text-foreground">
            <svg
              class="w-5 h-5 text-emerald-500 shrink-0 mt-0.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Role deep-dive kustom</span>
          </li>
        </ul>

        <a
          href={`${dashboardUrl}/billing`}
          class="checkout-link w-full text-center py-3 text-sm font-semibold rounded-xl bg-primary text-primary-foreground hover:bg-primary/95 transition-all"
        >
          Langganan Pro
        </a>
      </div>

      <!-- 14-Day Sprint Plan -->
      <div
        class="rounded-3xl border border-border/50 bg-card p-8 flex flex-col gap-6 h-full transition-all duration-300 hover:shadow-lg hover:shadow-primary/5"
      >
        <div class="flex flex-col gap-1">
          <div class="flex items-center gap-2">
            <h3 class="text-xl font-bold text-foreground">14-Day Sprint</h3>
            <span
              class="px-2 py-0.5 text-[10px] font-semibold bg-amber-500/10 text-amber-500 border border-amber-500/20 rounded-full"
