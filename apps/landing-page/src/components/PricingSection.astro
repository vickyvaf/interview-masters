          >
          <span class="text-sm text-muted-foreground">/ paket</span>
        </div>

        <hr class="border-border/40" />

        <ul class="flex flex-col gap-3 flex-grow text-sm">
          <li class="flex items-start gap-3 text-foreground">
            <svg
              class="w-5 h-5 text-emerald-500 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Masa aktif program 14 hari</span>
          </li>
          <li class="flex items-start gap-3 text-foreground">
            <svg
              class="w-5 h-5 text-emerald-500 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Umpan balik instan & terstruktur</span>
          </li>
          <li class="flex items-start gap-3 text-foreground">
            <svg
              class="w-5 h-5 text-emerald-500 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Pertanyaan posisi spesifik & custom</span>
          </li>
          <li class="flex items-start gap-3 text-foreground">
            <svg
              class="w-5 h-5 text-emerald-500 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Dirancang khusus untuk wawancara &lt; 30 hari</span>
          </li>
        </ul>

        <a
          href={`${dashboardUrl}/billing`}
          class="checkout-link w-full text-center py-3 text-sm font-semibold rounded-xl bg-amber-500 hover:bg-amber-600 text-white transition-all"
        >
          Beli Paket Sprint
        </a>
      </div>
    </div>

    <!-- B2B Footer info -->
    <div
      class="mt-12 rounded-3xl border border-border/50 bg-card p-6 md:p-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 pricing-element opacity-0 translate-y-8 transition-all duration-700 ease-out transform delay-200"
    >
      <div class="flex flex-col gap-1">
        <h4 class="text-lg font-bold text-foreground">
          Kebutuhan Organisasi / B2B?
        </h4>
        <p class="text-sm text-muted-foreground max-w-2xl">
          Kami menyediakan lisensi massal, dasboard HR terintegrasi, dan
          kustomisasi pelacakan kandidat untuk universitas atau bootcamp.
        </p>
      </div>
      <a
        href="mailto:support@interviewmasters.id"
        class="w-full md:w-auto text-center px-6 py-3 text-sm font-semibold rounded-xl border border-border hover:bg-secondary text-foreground transition-all shrink-0"
      >
        Hubungi Kami
      </a>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove("opacity-0", "translate-y-8");
          entry.target.classList.add("opacity-100", "translate-y-0");
          observer.unobserve(entry.target);
        }
      });
    },
    {
      threshold: 0.1,
    },
  );

  document.querySelectorAll(".pricing-element").forEach((el) => {
    observer.observe(el);
  });

  // Client-side authentication routing check for pricing checkout links
  try {
    const cookies = document.cookie.split(';');
    const hasSession = cookies.some(c => c.trim().startsWith('im_session='));
    
    if (!hasSession) {
      const pricingSection = document.getElementById('pricing');
      const dashboardUrl = pricingSection ? pricingSection.getAttribute('data-dashboard-url') : 'http://localhost:5173';
      const checkoutLinks = document.querySelectorAll('.checkout-link');
      checkoutLinks.forEach(link => {
        // Redirect them to login page first
        link.setAttribute('href', `${dashboardUrl}/login?redirectTo=/billing`);
      });
    }
  } catch (e) {
    console.error('Error checking user session in PricingSection', e);
  }
</script>
