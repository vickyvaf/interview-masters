---
import "../styles/global.css";
import Navbar from "../components/Navbar";
import HeroSection from "../components/HeroSection";
import AnnouncementBanner from "../components/AnnouncementBanner";
import PopularJobs from "../components/PopularJobs.astro";
import LearnSection from "../components/LearnSection.astro";
import PricingSection from "../components/PricingSection.astro";
import GlobeSection from "../components/GlobeSection.astro";
import FaqSection from "../components/FaqSection.astro";
import Footer from "../components/Footer.astro";
---

<html lang="id">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content="index, follow" />
		<meta
			name="description"
			content="Persiapkan diri Anda menghadapi wawancara kerja dengan simulasi berbasis AI interaktif. Dapatkan feedback instan mengenai struktur jawaban (metode STAR), tingkat relevansi, rambling detector, dan revisi jawaban dari AI evaluator."
		/>
		<meta
			name="keywords"
			content="simulasi wawancara kerja, latihan wawancara, persiapan wawancara, wawancara kerja ai, mock interview ai, feedback wawancara kerja"
		/>
		<title>
			Interview Masters - Simulasi Wawancara Kerja AI Interaktif
		</title>

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta
			property="og:url"
			content="https://interviewmasters.netlify.app/"
		/>
		<meta
			property="og:title"
			content="Interview Masters - Simulasi Wawancara Kerja AI"
		/>
		<meta
			property="og:description"
			content="Latihan simulasi wawancara kerja interaktif dengan AI. Dapatkan analisis detail dan perbaikan jawaban instan menggunakan metode STAR."
		/>
		<meta property="og:image" content="/logo-new.png" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta
			property="twitter:url"
			content="https://interviewmasters.netlify.app/"
		/>
		<meta
			property="twitter:title"
			content="Interview Masters - Simulasi Wawancara Kerja AI"
		/>
		<meta
			property="twitter:description"
			content="Latihan simulasi wawancara kerja interaktif dengan AI. Dapatkan analisis detail dan perbaikan jawaban instan menggunakan metode STAR."
		/>
		<meta property="twitter:image" content="/logo-new.png" />

		<!-- Schema.org VideoObject Structured Data (Google Video Rich Snippets) -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "VideoObject",
				"name": "Simulasi Wawancara Kerja AI - Interview Masters",
				"description": "Latihan & simulasi wawancara kerja AI 100% dipersonalisasi untuk berbagai posisi pekerjaan. Dapatkan evaluasi instan metode STAR dan analisis skor kesiapan wawancara.",
				"thumbnailUrl": [
					"https://img.youtube.com/vi/DTbh09OeFwY/maxresdefault.jpg"
				],
				"uploadDate": "2026-07-24T00:00:00+07:00",
				"contentUrl": "https://youtu.be/DTbh09OeFwY",
				"embedUrl": "https://www.youtube.com/embed/DTbh09OeFwY"
			}
		</script>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link class="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>

		<!-- Structured Data (JSON-LD) for SEO / Google Sitelinks -->
		<script type="application/ld+json">
			[
				{
					"@context": "https://schema.org",
					"@type": "WebSite",
					"name": "Interview Masters",
					"url": "https://interviewmasters.netlify.app",
					"potentialAction": {
						"@type": "SearchAction",
						"target": "https://interviewmasters.netlify.app/?q={search_term_string}",
						"query-input": "required name=search_term_string"
					}
				},
				{
					"@context": "https://schema.org",
					"@type": "SiteNavigationElement",
					"@id": "#header-navigation",
					"name": [
						"Fitur Utama",
						"Paket & Harga",
						"Mulai Gratis",
						"Masuk Akun"
					],
					"url": [
						"https://interviewmasters.netlify.app/#features",
						"https://interviewmasters.netlify.app/#pricing",
						"https://dashboard-interviewmasters.netlify.app/register",
						"https://dashboard-interviewmasters.netlify.app/login"
					]
				},
				{
					"@context": "https://schema.org",
					"@type": "SoftwareApplication",
					"name": "Interview Masters",
					"operatingSystem": "All",
					"applicationCategory": "EducationalApplication",
					"offers": {
						"@type": "Offer",
						"price": "9000",
						"priceCurrency": "IDR"
					},
					"aggregateRating": {
						"@type": "AggregateRating",
						"ratingValue": "4.9",
						"ratingCount": "128",
						"bestRating": "5",
						"worstRating": "1"
					}
				},
				{
					"@context": "https://schema.org",
					"@type": "FAQPage",
					"mainEntity": [
						{
							"@type": "Question",
							"name": "Bagaimana simulasi wawancara kerja AI ini bekerja?",
							"acceptedAnswer": {
								"@type": "Answer",
								"text": "AI kami akan mengajukan pertanyaan satu per satu secara interaktif berdasarkan posisi pekerjaan yang Anda pilih serta deskripsi pekerjaan yang diunggah. Anda cukup menjawab secara lisan menggunakan mikrofon, dan mesin transkripsi kami akan mencatat tanggapan Anda secara real-time untuk dianalisis oleh AI evaluator."
							}
						},
						{
							"@type": "Question",
							"name": "Apakah saya langsung mendapatkan umpan balik setelah latihan selesai?",
							"acceptedAnswer": {
								"@type": "Answer",
								"text": "Ya! Segera setelah simulasi selesai, Anda akan disuguhkan dasbor analisis terperinci. Feedback kami mencakup penilaian struktur kalimat (menggunakan metode STAR: Situation, Task, Action, Result), tingkat relevansi, kepadatan penjelasan, pendeteksi rambling (bicara berputar-putar), serta rekomendasi revisi jawaban ('What you could have said')."
							}
						},
						{
							"@type": "Question",
							"name": "Metode pembayaran apa saja yang didukung?",
							"acceptedAnswer": {
								"@type": "Answer",
								"text": "Kami menerima berbagai metode pembayaran lokal Indonesia yang aman, termasuk pembayaran instan menggunakan QRIS, Virtual Account (BCA, Mandiri, BRI, BNI, dll), e-wallet, dan kartu debit/kredit lokal."
							}
						},
						{
							"@type": "Question",
							"name": "Apa perbedaan paket Pro bulanan dengan Starter Pass?",
							"acceptedAnswer": {
								"@type": "Answer",
								"text": "Paket Pro (Rp 29.000/bulan) memberikan akses latihan tanpa batas (unlimited) dan analitik lengkap setiap bulan. Sementara Starter Pass (Rp 9.000/paket) adalah paket sekali bayar tanpa langganan yang memberikan kuota 3x simulasi wawancara dengan masa aktif 1 bulan, dirancang bagi Anda yang ingin latihan cepat tanpa ikatan berlangganan."
							}
						},
						{
							"@type": "Question",
							"name": "Apakah saya bisa membatalkan langganan Pro kapan saja?",
							"acceptedAnswer": {
								"@type": "Answer",
								"text": "Tentu saja. Anda bisa membatalkan langganan paket Pro Anda kapan saja langsung melalui menu Billing di dasbor akun Anda. Setelah dibatalkan, akses fitur Pro akan tetap aktif hingga periode langganan bulan berjalan berakhir."
							}
						}
					]
				}
			]
		</script>

		<!-- Google tag (gtag.js) -->
		<script
			async
			src="https://www.googletagmanager.com/gtag/js?id=G-RMK63K97FM"
			is:inline></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag("js", new Date());

			gtag("config", "G-RMK63K97FM");
		</script>
	</head>
	<body style="margin:0;padding:0;font-family:'Inter',sans-serif;">
		<Navbar client:load />
		<div class="relative z-10">
			<HeroSection client:load />
			<AnnouncementBanner client:load />
		</div>
		<PopularJobs />
		<LearnSection />
		<GlobeSection />
		<PricingSection />
		<FaqSection />
		<Footer />
	</body>
</html>
