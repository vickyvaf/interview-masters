{
  "name": "interview-masters",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm dev:all",
    "dev:all": "pnpm --filter apps-landing-page dev & pnpm --filter apps-dashboard dev & PYTHONPATH=apps/backend ./apps/backend/.venv/bin/uvicorn main:app --port 5005 --reload --reload-dir apps/backend",
    "dev:landing": "pnpm --filter apps-landing-page dev",
    "dev:dashboard": "pnpm --filter apps-dashboard dev",
    "dev:backend": "PYTHONPATH=apps/backend ./apps/backend/.venv/bin/uvicorn main:app --port 5005 --reload --reload-dir apps/backend",
    "build:landing": "pnpm --filter apps-landing-page build",
    "build:dashboard": "pnpm --filter apps-dashboard build",
    "preview:landing": "pnpm --filter apps-landing-page preview"
  }
}
